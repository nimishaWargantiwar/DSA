#Solution:-
class Solution {
    public int numberOfSubmatrices(char[][] grid) {
        int m=grid.length;
        int n=grid[0].length;

        int both_XY[][]=new int[m][n];
        int atleast_one_X[][]=new int[m][n];


        for(int i=0;i<m;i++)
        {
            for(int j=0;j<n;j++)
            {
                if(grid[i][j]=='X')
                {
                    both_XY[i][j]=1;
                    atleast_one_X[i][j]=1;
                }
                else if(grid[i][j]=='Y')
                {
                    both_XY[i][j]=-1;
                     atleast_one_X[i][j]=0;
                }
                else 
                {
                    both_XY[i][j]=0;
                     atleast_one_X[i][j]=0;
                }
            }
        }

        for(int i=0;i<m;i++)
        {
            for(int j=0;j<n;j++)
            {
                if(i>0)
                {
                    both_XY[i][j]+=both_XY[i-1][j];
                     atleast_one_X[i][j]+=atleast_one_X[i-1][j];
                }

                if(j>0)
                {
                     both_XY[i][j]+=both_XY[i][j-1];
                     atleast_one_X[i][j]+=atleast_one_X[i][j-1];
                }

                if(i>0 && j>0)
                {
                     both_XY[i][j]-=both_XY[i-1][j-1];
                     atleast_one_X[i][j]-=atleast_one_X[i-1][j-1];
                }
            }
        }

        int count=0;
        for(int i=0;i<m;i++)
        {
            for(int j=0;j<n;j++)
            {
                if(both_XY[i][j]==0 && atleast_one_X[i][j]>=1)
                {
                    count++;
                }
            }
        }
        return count;
    }
}

int ans=0;
HashMap<Integer,Integer> hm = new HashMap<>();
for(int n1:nums)
{
    hm.put(n1,hm.getOrDefault(n1,0)+1);
}
for(int n1:hm.keySet())
{
    if(hm.get(n1)>n)
    {
        ans=n1;
    }
}
return ans;

Given a collection of candidate numbers (candidates) and a target number (target), find all unique combinations in candidates where the candidate numbers sum to target.

Each number in candidates may only be used once in the combination.

Note: The solution set must not contain duplicate combinations.

 

Example 1:

Input: candidates = [10,1,2,7,6,1,5], target = 8
Output: 
[
[1,1,6],
[1,2,5],
[1,7],
[2,6]
]
Example 2:

Input: candidates = [2,5,2,1,2], target = 5
Output: 
[
[1,2,2],
[5]
]





#Solution:-
class Solution {
    public List<List<Integer>> combinationSum2(int[] candidates, int target) {
        Arrays.sort(candidates);
        List<List<Integer>> ll = new ArrayList<>();

        p(candidates,target,0,ll,new ArrayList<>());
return ll;
    }

    public void p(int arr[],int target,int i,List<List<Integer>> res,List<Integer> curr)
    {
        if(target==0)
        {
            res.add(new ArrayList(curr));
            return;
        }

        if(target<0 || i==arr.length)
        {
            return;
        }



for(int p1=i;p1<arr.length;p1++)
{
    if(p1>i && arr[p1]==arr[p1-1])
    {
        continue;
    }

    if(arr[p1]>target)
    {
        break;
    }
        curr.add(arr[p1]);
        p(arr,target-arr[p1],p1+1,res,curr);
        curr.remove(curr.size()-1);

}
    }
}
